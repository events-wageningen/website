---
import type { Event } from "@/types/event";
import { formatDate, formatTime, type Category } from "@/lib/events";

export interface Props {
  event: Event;
  categoryMap?: Record<string, Category>;
}
const { event, categoryMap = {} } = Astro.props;

const priceLabel: Record<Event["price"], string> = {
  free: "Free",
  paid: "Paid",
  donation: "Donation",
};

const priceColor: Record<Event["price"], string> = {
  free: "bg-emerald-100 text-emerald-700",
  paid: "bg-blue-100 text-blue-700",
  donation: "bg-amber-100 text-amber-700",
};
---

<article
  data-categories={event.category.join(",")}
  data-event-id={event.id}
  class="event-card flex flex-col gap-3 rounded-2xl border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-md overflow-hidden cursor-pointer"
>
  <!-- Event image -->
  <img
    src={`${import.meta.env.BASE_URL}images/${event.id}.jpg`}
    alt={event.name}
    class="w-full h-40 object-cover"
    onerror={`this.onerror=null;this.src='${import.meta.env.BASE_URL}default.jpg'`}
  />

  <div class="flex flex-col gap-3 p-6 pt-3">
    <!-- Date & time -->
    <div class="flex items-center justify-between gap-2">
      <time
        datetime={event.startDate}
        class="text-sm font-semibold uppercase tracking-wide text-emerald-600"
      >
        {formatDate(event.startDate)} · {formatTime(event.startDate)}
      </time>
      <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${priceColor[event.price]}`}>
        {priceLabel[event.price]}
      </span>
    </div>

    <!-- Name -->
    <h2 class="text-xl font-bold leading-snug text-gray-900">
      {event.url ? (
        <a
          href={event.url}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:underline"
          data-no-modal
        >
          {event.name}
        </a>
      ) : event.name}
    </h2>

    <!-- Description -->
    {event.description && (
      <p class="text-sm text-gray-600 line-clamp-3">{event.description}</p>
    )}

    <!-- Location -->
    <p class="flex items-center gap-1.5 text-sm text-gray-500">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 shrink-0"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.079 3.218-4.474 3.218-7.327a8.5 8.5 0 00-17 0c0 2.853 1.274 5.248 3.218 7.327a19.58 19.58 0 002.669 2.268 16.975 16.975 0 001.148.746zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
          clip-rule="evenodd"
        ></path>
      </svg>
      {event.location.name}, {event.location.city}
    </p>

    <!-- Categories -->
    {event.category.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {event.category.map((cat) => {
          const info = categoryMap[cat];
          return (
            <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium capitalize text-gray-600">
              {info ? `${info.emoji} ${info.label}` : cat}
            </span>
          );
        })}
      </div>
    )}

    <!-- Tags -->
    {event.tags && event.tags.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {event.tags.map((tag) => (
          <span class="rounded-full bg-orange-50 px-2 py-0.5 text-xs text-orange-600">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- Organizer link button (bottom-right) -->
    {event.url && (
      <div class="flex justify-end mt-auto pt-2">
        <a
          href={event.url}
          target="_blank"
          rel="noopener noreferrer"
          data-no-modal
          class="inline-block rounded-full px-4 py-1.5 text-sm font-semibold text-white transition hover:opacity-90"
          style="background-color:#D1783B"
        >
          Link to event organizers →
        </a>
      </div>
    )}
  </div>
</article>
