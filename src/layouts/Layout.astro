---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Evenementen in Wageningen" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style is:global>
      :root {
        --brand: #4F7296;        /* muted steel blue */
        --brand-dark: #1E3A52;   /* deep navy */
        --brand-mid: #3A6284;    /* mid steel blue */
        --brand-hover: #365978;  /* hover state */
        --brand-bg: #F5F7FA;     /* off-white cool */
        --brand-border: #C5D6E8; /* light blue-gray border */
      }
      html { scroll-behavior: smooth; }
      body { font-family: 'Inter', system-ui, sans-serif; }

      /* Card reveal animation (triggered by IntersectionObserver) */
      .card-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.45s ease, transform 0.45s ease;
      }
      .card-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Smooth filter panel transition */
      #filter-panel {
        transition: opacity 0.2s ease;
      }
    </style>
  </head>
  <body class="min-h-screen text-gray-900" style="background-color:var(--brand-bg)">
    <slot />
  </body>
</html>
