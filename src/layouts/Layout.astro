---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Evenementen in Wageningen" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style is:global>
      :root {
        --brand: #1A2636;        /* much darker blue */
        --brand-dark: #101624;   /* almost black navy */
        --brand-mid: #22304A;    /* mid dark blue */
        --brand-hover: #2B3B54;  /* hover state */
        --brand-bg: #F5F7FA;     /* off-white cool */
        --brand-border: #B6C3D6; /* lighter border */
        --dot-navy: #1E3A8A;     /* navy blue for dots */
        --wave-tint: #6B8FB8;    /* soothed blue for wave wash */
      }
      html { scroll-behavior: smooth; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
        background-color: var(--brand-bg);
        position: relative;
        z-index: 0;
      }

      /* Static navy-blue square pattern — small squares, jittered ±3% inside 200px tile */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -2;
        pointer-events: none;
        background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='200' height='200'%3E%3Cg fill='%230A1530'%3E%3Crect x='23.5' y='21.5' width='5' height='5'/%3E%3Crect x='72.5' y='23.5' width='5' height='5'/%3E%3Crect x='123.5' y='21.5' width='5' height='5'/%3E%3Crect x='171.5' y='23.5' width='5' height='5'/%3E%3Crect x='21.5' y='73.5' width='5' height='5'/%3E%3Crect x='73.5' y='71.5' width='5' height='5'/%3E%3Crect x='121.5' y='73.5' width='5' height='5'/%3E%3Crect x='173.5' y='71.5' width='5' height='5'/%3E%3Crect x='23.5' y='121.5' width='5' height='5'/%3E%3Crect x='71.5' y='123.5' width='5' height='5'/%3E%3Crect x='123.5' y='121.5' width='5' height='5'/%3E%3Crect x='171.5' y='123.5' width='5' height='5'/%3E%3Crect x='22.5' y='173.5' width='5' height='5'/%3E%3Crect x='73.5' y='171.5' width='5' height='5'/%3E%3Crect x='122.5' y='173.5' width='5' height='5'/%3E%3Crect x='171.5' y='171.5' width='5' height='5'/%3E%3C/g%3E%3C/svg%3E");
        background-size: 200px 200px;
        background-repeat: repeat;
        opacity: 0.55;
      }

      /* Pulsing diagonal wave: bigger squares (aligned with static) + colored band, single band sweeping corner→corner, opacity-pulsing */
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background-image:
          url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='200' height='200'%3E%3Cg fill='%234F7296' fill-opacity='0.85'%3E%3Crect x='21' y='19' width='10' height='10'/%3E%3Crect x='70' y='21' width='10' height='10'/%3E%3Crect x='121' y='19' width='10' height='10'/%3E%3Crect x='169' y='21' width='10' height='10'/%3E%3Crect x='19' y='71' width='10' height='10'/%3E%3Crect x='71' y='69' width='10' height='10'/%3E%3Crect x='119' y='71' width='10' height='10'/%3E%3Crect x='171' y='69' width='10' height='10'/%3E%3Crect x='21' y='119' width='10' height='10'/%3E%3Crect x='69' y='121' width='10' height='10'/%3E%3Crect x='121' y='119' width='10' height='10'/%3E%3Crect x='169' y='121' width='10' height='10'/%3E%3Crect x='20' y='171' width='10' height='10'/%3E%3Crect x='71' y='169' width='10' height='10'/%3E%3Crect x='120' y='171' width='10' height='10'/%3E%3Crect x='169' y='169' width='10' height='10'/%3E%3C/g%3E%3C/svg%3E"),
          linear-gradient(135deg, transparent 35%, rgba(91, 127, 181, 0.55) 50%, transparent 65%);
        background-size: 200px 200px, 100% 100%;
        background-position: 0 0, 0 0;
        background-repeat: repeat, no-repeat;
        -webkit-mask-image: linear-gradient(135deg, transparent 32%, rgba(0,0,0,1) 50%, transparent 68%);
        mask-image: linear-gradient(135deg, transparent 32%, rgba(0,0,0,1) 50%, transparent 68%);
        -webkit-mask-size: 220% 220%;
        mask-size: 220% 220%;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        animation: wave-diagonal 9s linear infinite, wave-pulse 1.6s ease-in-out infinite;
      }
      @keyframes wave-diagonal {
        0%   { -webkit-mask-position: 200% 200%; mask-position: 200% 200%; }
        100% { -webkit-mask-position: -120% -120%; mask-position: -120% -120%; }
      }
      @keyframes wave-pulse {
        0%, 100% { opacity: 0.55; }
        50%      { opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) {
        body::after { animation: none; }
      }

      /* Card reveal animation (triggered by IntersectionObserver) */
      .card-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.45s ease, transform 0.45s ease;
      }
      .card-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Smooth filter panel transition */
      #filter-panel {
        transition: opacity 0.2s ease;
      }
    </style>
  </head>
  <body class="min-h-screen text-gray-900" style="background-color:var(--brand-bg)">
    <slot />
  </body>
</html>
