---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Evenementen in Wageningen" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style is:global>
      :root {
        --brand: #1A2636;        /* much darker blue */
        --brand-dark: #101624;   /* almost black navy */
        --brand-mid: #22304A;    /* mid dark blue */
        --brand-hover: #2B3B54;  /* hover state */
        --brand-bg: #F5F7FA;     /* off-white cool */
        --brand-border: #B6C3D6; /* lighter border */
      }
      html { scroll-behavior: smooth; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
        background: var(--brand-bg);
        position: relative;
        z-index: 0;
      }

      /* Animated wavy grid of points with colored wave overlay */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        width: 100vw;
        height: 100vh;
        background: var(--brand-bg);
        opacity: 1;
      }
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -2;
        pointer-events: none;
        width: 100vw;
        height: 100vh;
        background: repeating-radial-gradient(circle at 0 0, #B6C3D6 1.5px, transparent 7px), repeating-radial-gradient(circle at 40px 40px, #B6C3D6 1.5px, transparent 7px);
        background-size: 80px 80px;
        opacity: 0.18;
        animation: grid-move 12s linear infinite alternate;
      }
      @keyframes grid-move {
        0% { background-position: 0 0, 40px 40px; }
        100% { background-position: 40px 20px, 0px 60px; }
      }
      .wavy-wave {
        position: fixed;
        left: 0; right: 0; bottom: 0;
        width: 100vw;
        height: 180px;
        z-index: -1;
        pointer-events: none;
        opacity: 0.7;
        mix-blend-mode: multiply;
        animation: wave-move 10s ease-in-out infinite alternate;
      }
      @keyframes wave-move {
        0% { transform: translateY(0) scaleX(1); }
        100% { transform: translateY(10px) scaleX(1.04); }
      }

      /* Card reveal animation (triggered by IntersectionObserver) */
      .card-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.45s ease, transform 0.45s ease;
      }
      .card-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Smooth filter panel transition */
      #filter-panel {
        transition: opacity 0.2s ease;
      }
    </style>
  </head>
  <body class="min-h-screen text-gray-900" style="background-color:var(--brand-bg)">
    <slot />
  </body>
</html>
