---
import Layout from "@/layouts/Layout.astro";
import EventCard from "@/components/EventCard.astro";
import { getEvents, getCategories, type Category } from "@/lib/events";

const [events, categoriesList] = await Promise.all([getEvents(), getCategories()]);
const categoryMap = Object.fromEntries(categoriesList.map((c) => [c.id, c])) as Record<string, Category>;
const now = new Date();
const upcomingEvents = events
  .filter((e) => new Date(e.startDate) >= now)
  .sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());
const pastEvents = events
  .filter((e) => new Date(e.startDate) < now)
  .sort((a, b) => new Date(b.startDate).getTime() - new Date(a.startDate).getTime());
---

<Layout title="Events in Wageningen">
  <header class="bg-white flex items-center justify-center" style="height:160px">
    <img
      src={`${import.meta.env.BASE_URL}logo.jpg`}
      alt="Events Wageningen"
      class="h-full w-auto object-contain"
    />
  </header>

  <main class="mx-auto max-w-5xl px-4 py-10">

    <!-- Filter toggle tab -->
    <div class="mb-4 flex justify-center">
      <button
        id="filter-toggle"
        class="flex items-center gap-2 rounded-full border border-gray-300 bg-white px-10 py-2.5 text-sm font-semibold text-gray-700 shadow-sm transition hover:border-orange-400 hover:text-orange-600"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
          <line x1="11" y1="18" x2="13" y2="18"/>
        </svg>
        Filters
      </button>
    </div>

    <!-- Filter panel (hidden by default) -->
    <div id="filter-panel" style="display:none" class="mb-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">

      {categoriesList.length > 0 && (
        <div class="mb-5">
          <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-400">Categories</p>
          <div class="flex flex-wrap gap-2">
            {categoriesList.map((cat) => (
              <button
                data-cat={cat.id}
                class="filter-btn rounded-full border border-gray-300 bg-white px-3 py-1 text-sm font-medium text-gray-600 transition hover:border-orange-400 hover:text-orange-600"
              >
                {cat.emoji} {cat.label}
              </button>
            ))}
          </div>
        </div>
      )}

      <div class="border-t border-gray-100 pt-5 pb-5">
        <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-gray-400">Starting date</p>
        <div class="flex flex-wrap items-center gap-4">
          <div class="flex items-center gap-2">
            <label for="filter-from" class="text-sm text-gray-600 whitespace-nowrap">From</label>
            <input
              type="date"
              id="filter-from"
              class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-700 focus:border-orange-400 focus:outline-none"
            />
          </div>
          <div class="flex items-center gap-2">
            <label for="filter-to" class="text-sm text-gray-600 whitespace-nowrap">To</label>
            <input
              type="date"
              id="filter-to"
              class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-700 focus:border-orange-400 focus:outline-none"
            />
          </div>
        </div>
      </div>

      <div class="border-t border-gray-100 pt-5 pb-5">
        <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-gray-400">Price</p>
        <div class="flex flex-wrap gap-2">
          {(["free", "paid", "donation"] as const).map((p) => (
            <button
              data-price={p}
              class="price-btn rounded-full border border-gray-300 bg-white px-3 py-1 text-sm font-medium text-gray-600 transition hover:border-orange-400 hover:text-orange-600"
            >
              {p === "free" ? "✨ Free" : p === "paid" ? "💰 Paid" : "🙏 Donation"}
            </button>
          ))}
        </div>
      </div>

      <div class="border-t border-gray-100 pt-5">
        <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-gray-400">City</p>
        <div class="flex flex-wrap gap-2" id="city-filters">
          {["Wageningen", "Droevendaal", "Bennekom", "Renkum", "Ede", "Rhenen"].map((city) => (
            <button
              data-city={city}
              class="city-btn rounded-full border border-gray-300 bg-white px-3 py-1 text-sm font-medium text-gray-600 transition hover:border-orange-400 hover:text-orange-600"
            >
              {city}
            </button>
          ))}
        </div>
      </div>

      <div class="flex items-center justify-between pt-5">
        <button
          id="filter-collapse"
          aria-label="Close filters"
          class="rounded-full border border-gray-200 px-3 py-1.5 text-gray-400 transition hover:border-orange-300 hover:text-orange-500 leading-none"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
        </button>
        <button
          id="filter-clear"
          class="rounded-full border border-gray-200 px-4 py-1.5 text-sm text-gray-500 transition hover:border-orange-300 hover:text-orange-500"
        >
          Clear all
        </button>
      </div>
    </div>

    {
      events.length === 0 ? (
        <p class="text-center text-gray-500 text-lg py-20">
          No events planned. Check back soon!
        </p>
      ) : (
        <>
          {upcomingEvents.length > 0 && (
            <section id="section-upcoming">
              <h2 class="mb-6 text-2xl font-bold" style="color:#99582B">
                Upcoming events
              </h2>
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {upcomingEvents.map((event) => (
                  <EventCard event={event} categoryMap={categoryMap} />
                ))}
              </div>
            </section>
          )}

          {pastEvents.length > 0 && (
            <section id="section-past" class="mt-14">
              <h2 class="mb-6 text-2xl font-bold" style="color:#C29B78">
                Past events
              </h2>
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 opacity-60">
                {pastEvents.map((event) => (
                  <EventCard event={event} categoryMap={categoryMap} />
                ))}
              </div>
            </section>
          )}
        </>
      )
    }
  </main>

  <footer class="mt-10 border-t border-gray-200 py-6 text-center text-sm text-gray-400">
    © {new Date().getFullYear()} Events Wageningen
  </footer>

  <!-- Event detail modal -->
  <div id="event-modal" style="display:none" class="fixed inset-0 z-50 overflow-y-auto">
    <div id="modal-overlay" class="fixed inset-0" style="background:rgba(0,0,0,0.75)"></div>
    <div class="relative flex min-h-full items-start justify-center p-6 sm:p-14">
      <div id="modal-panel" class="relative w-full max-w-2xl rounded-2xl bg-white shadow-2xl overflow-hidden">
        <button
          id="modal-close"
          class="absolute right-3 top-3 z-10 flex h-8 w-8 items-center justify-center rounded-full text-white text-2xl font-bold leading-none"
          style="background:rgba(0,0,0,0.45)"
          aria-label="Close"
        >&times;</button>
        <img id="modal-img" src="" alt="" class="w-full h-auto block" style="min-height:4rem;background:#f3f4f6" />
        <div class="p-6 flex flex-col gap-4">
          <div class="flex items-center justify-between gap-2 flex-wrap">
            <time id="modal-time" class="text-sm font-semibold uppercase tracking-wide text-emerald-600"></time>
            <span id="modal-price" class="rounded-full px-2.5 py-0.5 text-xs font-semibold"></span>
          </div>
          <h2 id="modal-name" class="text-2xl font-bold text-gray-900"></h2>
          <p id="modal-location" class="text-sm text-gray-500"></p>
          <div id="modal-maps-btn" style="display:none;position:relative;margin-top:0.25rem;border-radius:0.75rem;overflow:hidden">
            <div id="modal-map" style="height:260px"></div>
            <a
              id="modal-maps-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              data-no-modal
              style="position:absolute;top:8px;right:8px;z-index:1000;background:white;box-shadow:0 1px 5px rgba(0,0,0,0.3)"
              class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold text-gray-700 transition hover:text-orange-600"
            >&#x1F30D; Open in Maps</a>
          </div>
          <p id="modal-desc" class="text-sm text-gray-700 whitespace-pre-line"></p>
          <div id="modal-cats" class="flex flex-wrap gap-1.5"></div>
          <div id="modal-tags" class="flex flex-wrap gap-1"></div>
          <div class="flex items-center justify-between gap-3 pt-4 flex-wrap">
            <div class="relative">
              <button
                id="modal-cal-btn"
                data-no-modal
                class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold text-white transition hover:opacity-90"
                style="background-color:#4a9e6b"
              >&#x1F4C5; Add to calendar</button>
              <!-- calendar dropdown -->
              <div id="modal-cal-menu" style="display:none;position:absolute;left:0;bottom:calc(100% + 6px);z-index:200;min-width:200px" class="rounded-xl border border-gray-200 bg-white shadow-lg overflow-hidden">
                <a id="modal-cal-google" href="#" target="_blank" rel="noopener noreferrer" data-no-modal
                  class="flex items-center gap-2 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 border-b border-gray-100">
                  <img src="https://calendar.google.com/googlecalendar/images/favicon_v2014_2.ico" width="16" height="16" alt="" onerror="this.style.display='none'" />
                  Google Calendar
                </a>
                <button id="modal-cal-ics" data-no-modal
                  class="flex w-full items-center gap-2 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50">
                  &#x1F4E5; Download .ics
                </button>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <a id="modal-contact" href="https://t.me/+oF-vs0yFaF9hMmQ8" target="_blank" rel="noopener noreferrer" data-no-modal
                style="font-size:0.7rem"
                class="text-gray-300 hover:text-gray-400 transition"
              >If this post should not be here, contact us</a>
              <a
                id="modal-link"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block rounded-full px-4 py-1.5 text-sm font-semibold text-white transition hover:opacity-90"
                style="background-color:#D1783B;display:none"
              >Link to event organizers →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ eventsData: events, categoryMapData: categoryMap, siteBaseUrl: import.meta.env.BASE_URL }}>
  // ── Filter panel toggle ────────────────────────────────────────────────────
  const filterToggle = document.getElementById('filter-toggle');
  const filterPanel  = document.getElementById('filter-panel');
  function closeFilterPanel() {
    filterPanel.style.display = 'none';
    filterToggle.style.backgroundColor = '';
    filterToggle.style.color           = '';
    filterToggle.style.borderColor     = '';
  }

  filterToggle.addEventListener('click', () => {
    const open = filterPanel.style.display !== 'none';
    if (open) {
      closeFilterPanel();
    } else {
      filterPanel.style.display = '';
      filterToggle.style.backgroundColor = '#D1783B';
      filterToggle.style.color           = '#fff';
      filterToggle.style.borderColor     = '#D1783B';
    }
  });

  document.getElementById('filter-collapse').addEventListener('click', closeFilterPanel);

  // ── Filters: shared state ──────────────────────────────────────────────────
  const filterBtns    = document.querySelectorAll('.filter-btn');
  const cityBtns      = document.querySelectorAll('.city-btn');
  const priceBtns     = document.querySelectorAll('.price-btn');
  const cards         = document.querySelectorAll('article[data-categories]');
  const sectionUpcoming = document.getElementById('section-upcoming');
  const sectionPast   = document.getElementById('section-past');
  const filterFrom    = document.getElementById('filter-from');
  const filterTo      = document.getElementById('filter-to');
  const filterClear   = document.getElementById('filter-clear');
  const selectedCats  = new Set();
  const selectedCities = new Set();
  const selectedPrices = new Set();

  function applyFilter() {
    const from = filterFrom.value ? new Date(filterFrom.value) : null;
    const to   = filterTo.value   ? new Date(filterTo.value + 'T23:59:59') : null;

    cards.forEach((card) => {
      const catOk = selectedCats.size === 0 ||
        (card.dataset.categories ?? '').split(',').filter(Boolean).some((c) => selectedCats.has(c));

      const ev = eventsData.find((x) => x.id === card.dataset.eventId);
      let dateOk = true;
      let cityOk = true;
      let priceOk = true;
      if (ev) {
        const start = new Date(ev.startDate);
        if (from && start < from) dateOk = false;
        if (to   && start > to)   dateOk = false;
        if (selectedCities.size > 0 && !selectedCities.has(ev.location.city)) cityOk = false;
        if (selectedPrices.size > 0 && !selectedPrices.has(ev.price)) priceOk = false;
      }
      card.style.display = catOk && dateOk && cityOk && priceOk ? '' : 'none';
    });

    [sectionUpcoming, sectionPast].forEach((section) => {
      if (!section) return;
      const visible = [...section.querySelectorAll('article[data-categories]')]
        .some((c) => c.style.display !== 'none');
      section.style.display = visible ? '' : 'none';
    });
  }

  function activateBtn(btn) {
    btn.style.backgroundColor = '#D1783B';
    btn.style.color = '#fff';
    btn.style.borderColor = '#D1783B';
  }
  function deactivateBtn(btn) {
    btn.style.backgroundColor = '';
    btn.style.color = '';
    btn.style.borderColor = '';
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      if (selectedCats.has(cat)) { selectedCats.delete(cat); deactivateBtn(btn); }
      else                        { selectedCats.add(cat);    activateBtn(btn); }
      applyFilter();
    });
  });

  cityBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const city = btn.dataset.city;
      if (selectedCities.has(city)) { selectedCities.delete(city); deactivateBtn(btn); }
      else                           { selectedCities.add(city);    activateBtn(btn); }
      applyFilter();
    });
  });

  priceBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const price = btn.dataset.price;
      if (selectedPrices.has(price)) { selectedPrices.delete(price); deactivateBtn(btn); }
      else                            { selectedPrices.add(price);    activateBtn(btn); }
      applyFilter();
    });
  });

  filterFrom.addEventListener('change', applyFilter);
  filterTo.addEventListener('change', applyFilter);

  filterClear.addEventListener('click', () => {
    selectedCats.clear();
    selectedCities.clear();
    selectedPrices.clear();
    filterBtns.forEach(deactivateBtn);
    cityBtns.forEach(deactivateBtn);
    priceBtns.forEach(deactivateBtn);
    filterFrom.value = '';
    filterTo.value = '';
    applyFilter();
  });

  // ── Event detail modal ─────────────────────────────────────────────────────
  const modal      = document.getElementById('event-modal');
  const modalClose = document.getElementById('modal-close');
  const modalImg   = document.getElementById('modal-img');
  const modalTime  = document.getElementById('modal-time');
  const modalPrice = document.getElementById('modal-price');
  const modalName  = document.getElementById('modal-name');
  const modalLoc   = document.getElementById('modal-location');
  const modalDesc  = document.getElementById('modal-desc');
  const modalCats  = document.getElementById('modal-cats');
  const modalTags  = document.getElementById('modal-tags');
  const modalLink    = document.getElementById('modal-link');
  const modalCalBtn  = document.getElementById('modal-cal-btn');
  const modalCalMenu = document.getElementById('modal-cal-menu');
  let _currentEvent  = null;

  const PRICE_LABELS = { free: 'Free', paid: 'Paid', donation: 'Donation' };
  const PRICE_COLORS = {
    free: 'bg-emerald-100 text-emerald-700',
    paid: 'bg-blue-100 text-blue-700',
    donation: 'bg-amber-100 text-amber-700',
  };

  function fmtDate(iso) {
    return new Date(iso).toLocaleDateString('en-GB', {
      weekday: 'short', day: 'numeric', month: 'long', year: 'numeric',
    });
  }
  function fmtTime(iso) {
    return new Date(iso).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
  }

  // ── Leaflet lazy loader ────────────────────────────────────────────────────────────
  let _leafletReady = false;
  let _leafletLoading = null;
  let _mapInstance = null;
  let _mapMarker = null;

  function loadLeaflet() {
    if (_leafletReady) return Promise.resolve();
    if (_leafletLoading) return _leafletLoading;
    _leafletLoading = new Promise((resolve) => {
      const cssLink = document.createElement('link');
      cssLink.rel = 'stylesheet';
      cssLink.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
      document.head.appendChild(cssLink);
      const jsScript = document.createElement('script');
      jsScript.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      jsScript.onload = () => { _leafletReady = true; resolve(undefined); };
      document.head.appendChild(jsScript);
    });
    return _leafletLoading;
  }

  async function openModal(ev) {
    _currentEvent = ev;
    modalImg.src = siteBaseUrl + 'images/' + ev.id + '.jpg';
    modalImg.alt = ev.name;
    modalImg.onerror = () => { modalImg.onerror = null; modalImg.src = siteBaseUrl + 'default.jpg'; };

    const hasEnd = ev.endDate && ev.endDate !== ev.startDate;
    if (hasEnd) {
      const sameDay = fmtDate(ev.startDate) === fmtDate(ev.endDate);
      if (sameDay) {
        modalTime.textContent = fmtDate(ev.startDate) + ' \u00b7 ' + fmtTime(ev.startDate) + ' \u2013 ' + fmtTime(ev.endDate);
      } else {
        modalTime.textContent = fmtDate(ev.startDate) + ' \u00b7 ' + fmtTime(ev.startDate) + ' \u2013 ' + fmtDate(ev.endDate) + ' \u00b7 ' + fmtTime(ev.endDate);
      }
    } else {
      modalTime.textContent = fmtDate(ev.startDate) + ' \u00b7 ' + fmtTime(ev.startDate);
    }
    modalPrice.textContent = PRICE_LABELS[ev.price] || ev.price;
    modalPrice.className = 'rounded-full px-2.5 py-0.5 text-xs font-semibold ' + (PRICE_COLORS[ev.price] || '');

    modalName.textContent = ev.name;
    modalLoc.textContent  = '\uD83D\uDCCD ' + ev.location.name + ', ' + ev.location.city;

    modalDesc.textContent   = ev.description || '';
    modalDesc.style.display = ev.description ? '' : 'none';

    modalCats.innerHTML = '';
    (ev.category || []).forEach((cat) => {
      const info = categoryMapData[cat];
      const span = document.createElement('span');
      span.className = 'rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium capitalize text-gray-600';
      span.textContent = info ? info.emoji + '\u00A0' + info.label : cat;
      modalCats.appendChild(span);
    });

    modalTags.innerHTML = '';
    (ev.tags || []).forEach((tag) => {
      const span = document.createElement('span');
      span.className = 'rounded-full bg-orange-50 px-2 py-0.5 text-xs text-orange-600';
      span.textContent = '#' + tag;
      modalTags.appendChild(span);
    });

    if (ev.url) {
      modalLink.href = ev.url;
      modalLink.style.display = '';
    } else {
      modalLink.style.display = 'none';
    }

    // contact link is always visible (fixed group URL)

    // ── Map + Maps button ─────────────────────────────────────────────────────
    const mapsBtn  = document.getElementById('modal-maps-btn');
    const mapsLink = document.getElementById('modal-maps-link');
    if (ev.lat != null && ev.lon != null) {
      mapsLink.href = `https://maps.google.com/?q=${ev.lat},${ev.lon}`;
      mapsBtn.style.display = '';
      await loadLeaflet();
      if (!_mapInstance) {
        _mapInstance = L.map('modal-map').setView([ev.lat, ev.lon], 16);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '\u00a9 <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(_mapInstance);
        _mapMarker = L.marker([ev.lat, ev.lon]).addTo(_mapInstance);
      } else {
        _mapInstance.setView([ev.lat, ev.lon], 16);
        _mapMarker.setLatLng([ev.lat, ev.lon]);
      }
      requestAnimationFrame(() => _mapInstance.invalidateSize());
    } else {
      mapsBtn.style.display = 'none';
    }

    modal.style.display = '';
    modal.scrollTop = 0;
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    setTimeout(() => { modalImg.src = ''; }, 200);
  }

  document.querySelectorAll('.event-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      if (e.target.closest('[data-no-modal]')) return;
      const ev = eventsData.find((x) => x.id === card.dataset.eventId);
      if (ev) openModal(ev).catch(console.error);
    });
  });

  modalClose.addEventListener('click', closeModal);
  // Close when clicking the darkened area outside the panel
  modal.addEventListener('click', (e) => {
    if (!e.target.closest('#modal-panel')) closeModal();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ── Calendar dropdown ─────────────────────────────────────────────────────
  function toICSDate(iso) {
    return new Date(iso).toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
  }
  function escICS(str) {
    return (str || '').replace(/\\/g, '\\\\').replace(/;/g, '\\;').replace(/,/g, '\\,').replace(/\n/g, '\\n');
  }
  function buildICS(ev) {
    const dtStart = toICSDate(ev.startDate);
    const endMs = ev.endDate && ev.endDate !== ev.startDate
      ? new Date(ev.endDate).getTime()
      : new Date(ev.startDate).getTime() + 2 * 3600 * 1000;
    const dtEnd = toICSDate(new Date(endMs).toISOString());
    return [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//Events Wageningen//EN',
      'CALSCALE:GREGORIAN',
      'METHOD:PUBLISH',
      'BEGIN:VEVENT',
      `UID:${ev.id}@events-wageningen.nl`,
      `DTSTART:${dtStart}`,
      `DTEND:${dtEnd}`,
      `SUMMARY:${escICS(ev.name)}`,
      `LOCATION:${escICS(ev.location.name + ', ' + ev.location.city)}`,
      ev.description ? `DESCRIPTION:${escICS(ev.description)}` : null,
      ev.url ? `URL:${ev.url}` : null,
      'END:VEVENT',
      'END:VCALENDAR',
    ].filter(Boolean).join('\r\n');
  }
  function toGCalDate(iso) {
    return new Date(iso).toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
  }

  // Toggle dropdown
  modalCalBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = modalCalMenu.style.display !== 'none';
    modalCalMenu.style.display = open ? 'none' : '';
    // Update Google Calendar URL with current event
    if (!open && _currentEvent) {
      const ev = _currentEvent;
      const endMs = ev.endDate && ev.endDate !== ev.startDate
        ? new Date(ev.endDate).getTime()
        : new Date(ev.startDate).getTime() + 2 * 3600 * 1000;
      const gcStart = toGCalDate(ev.startDate);
      const gcEnd   = toGCalDate(new Date(endMs).toISOString());
      const gcUrl = 'https://calendar.google.com/calendar/render?action=TEMPLATE'
        + `&text=${encodeURIComponent(ev.name)}`
        + `&dates=${gcStart}/${gcEnd}`
        + `&details=${encodeURIComponent(ev.description || '')}`
        + `&location=${encodeURIComponent(ev.location.name + ', ' + ev.location.city)}`;
      document.getElementById('modal-cal-google').href = gcUrl;
    }
  });
  // Close dropdown when clicking elsewhere
  document.addEventListener('click', () => { modalCalMenu.style.display = 'none'; });
  modalCalMenu.addEventListener('click', (e) => e.stopPropagation());

  // Download .ics
  document.getElementById('modal-cal-ics').addEventListener('click', () => {
    const ev = _currentEvent;
    if (!ev) return;
    modalCalMenu.style.display = 'none';
    const blob = new Blob([buildICS(ev)], { type: 'text/calendar;charset=utf-8' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = (ev.slug || ev.id) + '.ics';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });
</script>
