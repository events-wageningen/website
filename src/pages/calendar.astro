---
import Layout from "@/layouts/Layout.astro";
import { getEvents } from "@/lib/events";

const events = await getEvents();
const BASE_URL = import.meta.env.BASE_URL;
---

<Layout title="Events Calendar · Events Wageningen">
  <header class="relative flex items-center justify-center bg-white border-b border-orange-100 shadow-sm" style="height:140px">
    <!-- Back to list -->
    <a
      href={BASE_URL}
      class="absolute left-4 top-1/2 -translate-y-1/2 flex items-center gap-1.5 rounded-full border border-orange-200 bg-white px-3 py-2 text-xs font-semibold text-orange-700 shadow-sm transition-all duration-200 hover:bg-orange-50 hover:border-orange-400 hover:text-orange-900 hover:shadow-md"
      aria-label="All events list"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      <span class="hidden sm:inline">All events</span>
    </a>
    <!-- Logo links to home -->
    <a href={BASE_URL} class="block h-full py-4 transition-transform duration-300 hover:scale-105" aria-label="Back to homepage">
      <img src={`${BASE_URL}logo.jpg`} alt="Events Wageningen" class="h-full w-auto object-contain" />
    </a>
  </header>

  <main class="mx-auto max-w-5xl px-4 py-10">
    <!-- Month navigation -->
    <div class="mb-6 flex items-center justify-between gap-4">
      <button
        id="prev-month"
        class="flex h-9 w-9 items-center justify-center rounded-full border border-gray-300 bg-white text-gray-600 shadow-sm transition-all duration-200 hover:border-orange-400 hover:text-orange-600 hover:shadow-md"
        aria-label="Previous month"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <h1 id="month-title" class="text-xl font-extrabold tracking-tight" style="color:#7C2D12"></h1>
      <button
        id="next-month"
        class="flex h-9 w-9 items-center justify-center rounded-full border border-gray-300 bg-white text-gray-600 shadow-sm transition-all duration-200 hover:border-orange-400 hover:text-orange-600 hover:shadow-md"
        aria-label="Next month"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <!-- Weekday headers -->
    <div class="cal-grid mb-1">
      {["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"].map((d) => (
        <div class="py-2 text-center text-xs font-semibold uppercase tracking-wider text-gray-400">{d}</div>
      ))}
    </div>

    <!-- Calendar cells (filled by JS) -->
    <div id="calendar-cells" class="cal-grid"></div>
  </main>

  <footer class="mt-10 border-t border-gray-200 py-6 text-center text-sm text-gray-400">
    © {new Date().getFullYear()} Events Wageningen
  </footer>
</Layout>

<style>
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-cell {
    min-height: 96px;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    background: #fff;
    padding: 6px 8px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .cal-cell:hover {
    border-color: #fed7aa;
    box-shadow: 0 2px 8px rgba(234,88,12,0.08);
  }
  .cal-cell.is-empty {
    background: transparent;
    border-color: transparent;
    pointer-events: none;
  }
  .cal-cell.is-today {
    border-color: #EA580C;
    box-shadow: 0 0 0 1px #EA580C;
  }
  .cal-cell.is-past {
    opacity: 0.55;
  }
  .cal-day-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: #6b7280;
    line-height: 1;
    margin-bottom: 2px;
  }
  .cal-cell.is-today .cal-day-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #EA580C;
    color: #fff;
  }
  .cal-event-pill {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    line-height: 1.3;
    padding: 2px 6px;
    border-radius: 20px;
    background: #FFF7ED;
    color: #9A3412;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .cal-event-pill:hover {
    background: #EA580C;
    color: #fff;
  }
  .cal-more {
    font-size: 0.65rem;
    color: #9ca3af;
    padding-left: 6px;
  }
  @media (max-width: 640px) {
    .cal-cell {
      min-height: 60px;
      padding: 4px 5px;
    }
    .cal-event-pill {
      font-size: 0.6rem;
      padding: 1px 4px;
    }
  }
</style>

<script define:vars={{ eventsData: events, siteBaseUrl: BASE_URL }}>
  let year  = new Date().getFullYear();
  let month = new Date().getMonth(); // 0-indexed

  const MONTH_NAMES = [
    "January","February","March","April","May","June",
    "July","August","September","October","November","December"
  ];

  function escHtml(str) {
    return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderCalendar() {
    document.getElementById('month-title').textContent = `${MONTH_NAMES[month]} ${year}`;

    // First weekday of month (Mon-first: 0=Mon, 6=Sun)
    const firstDayRaw   = new Date(year, month, 1).getDay(); // 0=Sun
    const startOffset   = (firstDayRaw + 6) % 7;
    const daysInMonth   = new Date(year, month + 1, 0).getDate();
    const today         = new Date();

    // Gather events for this month
    const monthEvents = eventsData.filter((ev) => {
      const d = new Date(ev.startDate);
      return d.getFullYear() === year && d.getMonth() === month;
    });

    // Group by day-of-month
    const byDay = {};
    monthEvents.forEach((ev) => {
      const d = new Date(ev.startDate).getDate();
      if (!byDay[d]) byDay[d] = [];
      byDay[d].push(ev);
    });

    let html = '';

    // Empty leading cells
    for (let i = 0; i < startOffset; i++) {
      html += '<div class="cal-cell is-empty"></div>';
    }

    // Day cells
    const todayY = today.getFullYear();
    const todayM = today.getMonth();
    const todayD = today.getDate();

    for (let d = 1; d <= daysInMonth; d++) {
      const isToday = todayY === year && todayM === month && todayD === d;
      const isPast  = new Date(year, month, d) < new Date(todayY, todayM, todayD);
      const dayEvs  = byDay[d] || [];

      const classes = [
        'cal-cell',
        isToday ? 'is-today' : '',
        isPast  ? 'is-past'  : '',
      ].filter(Boolean).join(' ');

      const pills = dayEvs.slice(0, 3).map((ev) =>
        `<a href="${siteBaseUrl}events/${escHtml(ev.slug)}/" class="cal-event-pill" title="${escHtml(ev.name)}">${escHtml(ev.name)}</a>`
      ).join('');

      const more = dayEvs.length > 3
        ? `<span class="cal-more">+${dayEvs.length - 3} more</span>`
        : '';

      html += `<div class="${classes}"><span class="cal-day-num">${d}</span>${pills}${more}</div>`;
    }

    document.getElementById('calendar-cells').innerHTML = html;
  }

  document.getElementById('prev-month').addEventListener('click', () => {
    month--;
    if (month < 0) { month = 11; year--; }
    renderCalendar();
  });

  document.getElementById('next-month').addEventListener('click', () => {
    month++;
    if (month > 11) { month = 0; year++; }
    renderCalendar();
  });

  renderCalendar();
</script>
